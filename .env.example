# Required: OpenAI API Key (get it at platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM Settings
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.1
MAX_RETRIES=3

# Optional: Base URL for corporate proxies
# OPENAI_BASE_URL=https://api.openai.com/v1

# Server and Logging Settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Path to the log file (leave empty to log to console only)
LOG_FILE=